<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- TV features -->
    <uses-feature android:name="android.hardware.type.tv" android:required="true" />
    <uses-feature android:name="android.hardware.screen.landscape" android:required="true" />
    <uses-feature android:name="android.software.leanback" android:required="true" />

    <!-- Disable touch screen requirement -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:name=".ReadBookApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ReadBookTV"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- Main Activity - Launcher -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Bind Activity -->
        <activity
            android:name=".ui.bind.BindActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Shelf Activity -->
        <activity
            android:name=".ui.shelf.ShelfActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".ui.lock.LockActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Reader Activity -->
        <activity
            android:name=".ui.reader.ReaderActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Sync Service -->
        <service
            android:name=".service.SyncService"
            android:exported="false" />

        <!-- Anti-Addiction Service -->
        <service
            android:name=".service.AntiAddictionService"
            android:exported="false" />

    </application>

</manifest>
