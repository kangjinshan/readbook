<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 应用主题 - AppCompat 兼容 -->
    <style name="Theme.ReadBookTV" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/theme_yellow_background</item>
        <item name="android:textColor">@color/theme_yellow_text</item>
    </style>

    <!-- 阅读器菜单样式 -->
    <style name="ReaderMenuStyle" parent="Theme.Leanback">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <!-- 书籍卡片样式 -->
    <style name="BookCardStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/book_card_normal</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

    <!-- 菜单按钮样式 -->
    <style name="MenuButtonStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:background">@drawable/menu_button_selector</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

    <!-- 设置按钮样式 -->
    <style name="SettingButtonStyle">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:background">@drawable/setting_button_selector</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>
</resources>
