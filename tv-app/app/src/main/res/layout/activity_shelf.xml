<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/theme_yellow_background"
        android:orientation="vertical">

        <!-- 标题栏 -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="32dp"
            android:paddingTop="22dp"
            android:paddingEnd="32dp"
            android:paddingBottom="10dp"
            android:text="@string/shelf_title"
            android:textColor="@color/theme_yellow_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- 书籍列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bookRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="20dp"
            android:paddingTop="6dp"
            android:paddingEnd="20dp"
            android:paddingBottom="10dp" />

        <!-- 空状态 -->
        <TextView
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/empty_shelf"
            android:textColor="@color/theme_yellow_secondary"
            android:textSize="28sp"
            android:visibility="gone" />

    </LinearLayout>

    <View
        android:id="@+id/brightnessOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:clickable="false"
        android:focusable="false" />

</FrameLayout>
