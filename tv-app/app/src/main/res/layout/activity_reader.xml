<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theme_yellow_background">

    <!-- 书名（阅读页隐藏，仅保留结构避免绑定变更） -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="24dp"
        android:textColor="@color/theme_yellow_secondary"
        android:textSize="24sp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/remainingTimeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/reader_remaining_time_bg"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:shadowColor="@android:color/black"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="4"
        android:text="剩余 00:00:00"
        android:textColor="@color/reader_timer_text"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 页码 -->
    <TextView
        android:id="@+id/pageInfoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="2dp"
        android:textColor="@color/theme_yellow_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 书签指示器 -->
    <View
        android:id="@+id/bookmarkIndicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="12dp"
        android:background="@color/accent"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/pageInfoText"
        app:layout_constraintEnd_toStartOf="@id/pageInfoText"
        app:layout_constraintTop_toTopOf="@id/pageInfoText" />

    <!-- 内容区域 -->
    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        app:layout_constraintBottom_toTopOf="@id/progressBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ScrollView
            android:id="@+id/nativeContentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never">

            <FrameLayout
                android:id="@+id/pageContentHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:id="@+id/pageContentStack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/contentText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:lineSpacingMultiplier="1.38"
                    android:textColor="@color/theme_yellow_text"
                    android:textSize="36sp"
                    android:visibility="gone" />
            </FrameLayout>
        </ScrollView>

        <WebView
            android:id="@+id/chapterWebView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:visibility="gone" />

    </FrameLayout>

    <View
        android:id="@+id/brightnessOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FF000000"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 加载指示器 -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 底部进度条 -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="56dp"
        android:layout_marginBottom="2dp"
        android:max="100"
        android:progressTint="@color/progress_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 菜单面板 -->
    <LinearLayout
        android:id="@+id/menuPanel"
        android:layout_width="680dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#E0000000"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="阅读设置"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/tabSettings"
                style="@style/MenuButtonStyle"
                android:text="@string/tab_settings" />

            <Button
                android:id="@+id/tabBookmarks"
                style="@style/MenuButtonStyle"
                android:layout_marginStart="8dp"
                android:text="@string/tab_bookmarks" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:text="@string/menu_font_size"
                    android:textColor="@color/white"
                    android:textSize="24sp" />

                <Button
                    android:id="@+id/fontSizeSmall"
                    style="@style/SettingButtonStyle"
                    android:text="@string/font_size_small" />

                <Button
                    android:id="@+id/fontSizeMedium"
                    style="@style/SettingButtonStyle"
                    android:layout_marginStart="8dp"
                    android:text="@string/font_size_medium" />

                <Button
                    android:id="@+id/fontSizeLarge"
                    style="@style/SettingButtonStyle"
                    android:layout_marginStart="8dp"
                    android:text="@string/font_size_large" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:text="@string/menu_theme"
                    android:textColor="@color/white"
                    android:textSize="24sp" />

                <Button
                    android:id="@+id/themeYellow"
                    style="@style/SettingButtonStyle"
                    android:text="@string/theme_yellow" />

                <Button
                    android:id="@+id/themeWhite"
                    style="@style/SettingButtonStyle"
                    android:layout_marginStart="8dp"
                    android:text="@string/theme_white" />

                <Button
                    android:id="@+id/themeDark"
                    style="@style/SettingButtonStyle"
                    android:layout_marginStart="8dp"
                    android:text="@string/theme_dark" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:text="@string/menu_brightness"
                    android:textColor="@color/white"
                    android:textSize="24sp" />

                <Button
                    android:id="@+id/brightnessNormal"
                    style="@style/SettingButtonStyle"
                    android:text="@string/brightness_normal" />

                <Button
                    android:id="@+id/brightnessDim15"
                    style="@style/SettingButtonStyle"
                    android:layout_marginStart="8dp"
                    android:text="@string/brightness_dim_15" />

                <Button
                    android:id="@+id/brightnessDim30"
                    style="@style/SettingButtonStyle"
                    android:layout_marginStart="8dp"
                    android:text="@string/brightness_dim_30" />

                <Button
                    android:id="@+id/brightnessDim45"
                    style="@style/SettingButtonStyle"
                    android:layout_marginStart="8dp"
                    android:text="@string/brightness_dim_45" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bookmarksPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/emptyBookmarksText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_bookmarks"
                android:textColor="@color/gray"
                android:textSize="20sp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/bookmarksList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/reader_menu_help"
            android:textColor="@color/gray"
            android:textSize="18sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
